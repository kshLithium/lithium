{
  "name": "lithium",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "productName": "Lithium",
  "author": "Lithium contributors",
  "description": "Lithium v0 desktop prototype",
  "main": "dist-electron/index.cjs",
  "type": "module",
  "scripts": {
    "postinstall": "tsx scripts/patch-oracle.mts && electron-builder install-app-deps",
    "generate:icons": "tsx scripts/generate-icons.mts",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:full": "concurrently -k \"npm:dev:renderer\" \"npm:dev:mobile-client\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:mobile-client": "vite --config vite.mobile.config.ts --host 0.0.0.0 --port 4173 --strictPort",
    "dev:main": "npm run generate:icons && tsup src/main/index.ts src/main/preload.ts --format cjs --out-dir dist-electron --external electron --external node-pty --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/index.cjs dist-electron/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 \"LITHIUM_APP_NAME=Lithium Dev\" electron dist-electron/index.cjs",
    "build": "npm run generate:icons && npm run build:main && npm run build:renderer && npm run build:mobile",
    "build:main": "tsup src/main/index.ts src/main/preload.ts --format cjs --out-dir dist-electron --external electron --external node-pty --clean",
    "build:renderer": "vite build",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "package:dir": "npm run build && electron-builder --dir",
    "package:open": "tsx scripts/open-packaged-app.mts",
    "dev:focus": "tsx scripts/focus-dev-app.mts",
    "dev:packaged": "npm run package:dir && npm run package:open",
    "dist:mac": "npm run build && electron-builder --mac",
    "rebuild:native": "electron-builder install-app-deps",
    "check:release": "npm run typecheck && npm test && npm run build && npm audit --omit=dev --audit-level=high",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:app": "vitest run src/testing/lithium-app-driver.test.ts",
    "test:watch": "vitest",
    "simulate:smoke": "tsx scripts/simulate-smoke.mts",
    "simulate:threads": "tsx scripts/simulate-threads.mts",
    "capture:readme": "tsx scripts/capture-readme-screens.mts",
    "probe:live": "tsx scripts/probe-live-loop.mts",
    "probe:strategist": "tsx scripts/strategist-browser-probe.mts",
    "preview": "vite preview",
    "preview:mobile": "vite preview --config vite.mobile.config.ts --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@steipete/oracle": "0.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "discord.js": "^14.25.1",
    "katex": "^0.16.40",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^4.10.38",
    "playwright-core": "^1.58.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "dev.lithium.app",
    "productName": "Lithium",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-mobile/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "build/icon.icns",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "icon": "build/icon.icns"
    }
  }
}
